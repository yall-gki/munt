generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.1.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  shadowDatabaseUrl = env("DATABASE_shadow_URL")
}

model User {
  id               String             @id @default(cuid())
  name             String?
  email            String?            @unique
  emailVerified    DateTime?
  username         String?            @unique
  image            String?
  accounts         Account[]
  backtests        Backtest[]
  balances         Balance[]
  portfolioHistory PortfolioHistory[]
  sessions         Session[]
  strategies       Strategy[]
  trades           Trade[]
  coins            UserCoin[]
  wallets          Wallet[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserCoin {
  userId       String
  coinId       String
  isOptimistic Boolean? @default(false)
  coin         Coin     @relation(fields: [coinId], references: [id])
  user         User     @relation(fields: [userId], references: [id])

  @@id([userId, coinId])
}

model Strategy {
  id        String       @id @default(cuid())
  userId    String
  name      String
  type      StrategyType
  settings  Json
  coinId    String?
  timeframe String?
  isActive  Boolean      @default(false)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  backtests Backtest[]
  coin      Coin?        @relation(fields: [coinId], references: [id])
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  trades    Trade[]
}

model Trade {
  id         String      @id @default(cuid())
  userId     String
  strategyId String?
  coinId     String
  mode       TradeMode
  entryPrice Float
  exitPrice  Float?
  amount     Float
  profitLoss Float?
  status     TradeStatus @default(OPEN)
  executedAt DateTime    @default(now())
  closedAt   DateTime?
  coin       Coin        @relation(fields: [coinId], references: [id])
  strategy   Strategy?   @relation(fields: [strategyId], references: [id])
  user       User        @relation(fields: [userId], references: [id])

  @@unique([id, userId])
}

model Wallet {
  id        String   @id @default(cuid())
  userId    String
  provider  String
  address   String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Backtest {
  id          String   @id @default(cuid())
  strategyId  String
  userId      String
  timeframe   String
  fromDate    DateTime
  toDate      DateTime
  pnlPercent  Float
  numTrades   Int
  winRate     Float?
  maxDrawdown Float?
  strategy    Strategy @relation(fields: [strategyId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Coin {
  id               String             @id
  name             String
  symbol           String
  image            String?
  balances         Balance[]
  portfolioHistory PortfolioHistory[]
  strategies       Strategy[]
  trades           Trade[]
  userCoins        UserCoin[]
}

model Balance {
  id        String   @id @default(cuid())
  userId    String
  coinId    String
  amount    Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  coin      Coin     @relation(fields: [coinId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, coinId])
}

model PortfolioHistory {
  id       String   @id @default(cuid())
  userId   String
  coinId   String
  date     DateTime @default(now())
  usdValue Float
  coin     Coin     @relation(fields: [coinId], references: [id])
  user     User     @relation(fields: [userId], references: [id])

  @@unique([userId, coinId, date])
}

enum StrategyType {
  DCA
  GRID
  INDICATOR
  MANUAL
}

enum TradeMode {
  TEST
  REAL
}

enum TradeStatus {
  OPEN
  CLOSED
  CANCELLED
}
