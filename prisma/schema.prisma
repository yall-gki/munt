
generator client {
  provider        = "prisma-client"
  output          = "../lib/prisma"  // your current output

      // ensures TS output is compatible
}

datasource db {
  provider = "postgresql"
 

}

model User {
  id               String   @id @default(cuid())
  name             String?
  emailVerified    DateTime?
  username         String?  @unique
  image            String?
  password         String? 
  email            String?   @unique
  accounts         Account[]
  backtests        Backtest[]
  balances         Balance[]
  notifications    Notification[]
  portfolioHistory PortfolioHistory[]
  sessions         Session[]
  snapshots        Snapshot[]
  strategies       Strategy[]
  trades           Trade[]
  coins            UserCoin[]
  wallets          Wallet[]
  walletTrades     WalletTrade[]
}


model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime
  type       VerificationTokenType @default(EMAIL_VERIFY)
  attempts   Int                   @default(0)
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt

  @@unique([identifier, token, type])
  @@index([identifier, type])
}

model UserCoin {
  userId       String
  coinId       String
  isOptimistic Boolean? @default(false)
  coin         Coin     @relation(fields: [coinId], references: [id])
  user         User     @relation(fields: [userId], references: [id])

  @@id([userId, coinId])
}

model Strategy {
  id        String       @id @default(cuid())
  userId    String
  name      String
  type      StrategyType
  settings  Json
  parameters Json?
  coinId    String?
  timeframe String?
  isActive  Boolean      @default(false)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  backtests Backtest[]
  coin      Coin?        @relation(fields: [coinId], references: [id])
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  trades    Trade[]
}

model Trade {
  id         String      @id @default(cuid())
  userId     String
  strategyId String?
  coinId     String
  mode       TradeMode
  entryPrice Float
  exitPrice  Float?
  amount     Float
  profitLoss Float?
  status     TradeStatus @default(OPEN)
  executedAt DateTime    @default(now())
  closedAt   DateTime?
  coin       Coin        @relation(fields: [coinId], references: [id])
  strategy   Strategy?   @relation(fields: [strategyId], references: [id])
  user       User        @relation(fields: [userId], references: [id])

  @@unique([id, userId])
}

model Wallet {
  id        String   @id @default(cuid())
  userId    String
  provider  String
  address   String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Backtest {
  id          String   @id @default(cuid())
  strategyId  String
  userId      String
  timeframe   String
  fromDate    DateTime
  toDate      DateTime
  pnlPercent  Float
  numTrades   Int
  winRate     Float?
  maxDrawdown Float?
  strategy    Strategy @relation(fields: [strategyId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Coin {
  id               String             @id
  name             String
  symbol           String
  image            String?
  balances         Balance[]
  portfolioHistory PortfolioHistory[]
  strategies       Strategy[]
  trades           Trade[]
  userCoins        UserCoin[]
  walletTradesFrom WalletTrade[]     @relation("WalletTradeFrom")
  walletTradesTo   WalletTrade[]     @relation("WalletTradeTo")
}

model Balance {
  id        String   @id @default(cuid())
  userId    String
  coinId    String
  amount    Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  coin      Coin     @relation(fields: [coinId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, coinId])
}

model PortfolioHistory {
  id       String   @id @default(cuid())
  userId   String
  coinId   String
  date     DateTime @default(now())
  usdValue Float
  coin     Coin     @relation(fields: [coinId], references: [id])
  user     User     @relation(fields: [userId], references: [id])

  @@unique([userId, coinId, date])
}

model WalletTrade {
  id         String            @id @default(cuid())
  userId     String
  fromCoinId String
  toCoinId   String
  fromAmount Float
  toAmount   Float
  fromPrice  Float
  toPrice    Float
  status     WalletTradeStatus @default(COMPLETED)
  executedAt DateTime          @default(now())
  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  fromCoin   Coin              @relation("WalletTradeFrom", fields: [fromCoinId], references: [id])
  toCoin     Coin              @relation("WalletTradeTo", fields: [toCoinId], references: [id])

  @@index([userId, executedAt])
  @@index([fromCoinId])
  @@index([toCoinId])
}

model Snapshot {
  id             String   @id @default(cuid())
  userId         String
  date           DateTime
  portfolioValue Float
  perCoinValue   Json
  realizedPL     Float
  unrealizedPL   Float
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  message   String
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, read])
}

enum StrategyType {
  DCAa
  GRID
  INDICATOR
  MANUAL
  HODL
  DCA
  SWING
  REBALANCING
  STAKING
  HISTORICAL_SIMULATION
}

enum TradeMode {
  TEST
  REAL
}

enum TradeStatus {
  OPEN
  CLOSED
  CANCELLED
}

enum VerificationTokenType {
  EMAIL_VERIFY
  PASSWORD_RESET
  EMAIL_OTP
}

enum WalletTradeStatus {
  COMPLETED
  FAILED
}
